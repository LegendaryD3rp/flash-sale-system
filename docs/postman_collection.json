        {
          "name": "✅ 6.3c 等待活动开始（轮询至 startTime 到达）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var url=pm.collectionVariables.get('base_url')+'/api/seckill/activity/'+pm.collectionVariables.get('activityId');",
                  "var tok=pm.collectionVariables.get('adminToken');",
                  "var MAX=20,DELAY=1000;",
                  "(function poll(n){",
                  "if(n>MAX){console.log('等待超时，继续执行...');return;}",
                  "pm.sendRequest({url:url,method:'GET',header:{'Authorization':'Bearer '+tok}},",
                  "function(e,r){",
                  "if(e){setTimeout(function(){poll(n+1)},DELAY);return;}",
                  "var act=r.json().data;",
                  "if(act&&act.startTime){",
                  "var st=new Date(act.startTime.replace(' ','T'));",
                  "var now=new Date();",
                  "if(now>=st){console.log('活动已开始（'+(n-1)+'s 等待），proceed');}",
                  "else{var w=Math.ceil((st-now)/1000);console.log('等待中...还需约'+w+'秒');setTimeout(function(){poll(n+1)},Math.min(DELAY,w*1000));}",
                  "}else{setTimeout(function(){poll(n+1)},DELAY);}",
                  "});})(1);"
                ],
                "type": "text/javascript"
              }
            }
          ],
