        {
          "name": "✅ 6.5 查询秒杀订单（轮询验证——MQ异步+WebSocket推送）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const baseUrl = pm.collectionVariables.get('base_url');",
                  "const token = pm.collectionVariables.get('token');",
                  "const userId = pm.collectionVariables.get('userId');",
                  "const aid = Number(pm.collectionVariables.get('activityId'));",
                  "const maxAttempts = 3;",
                  "const delayMs = 2000;",
                  "",
                  "function pollForOrder(attempt) {",
                  "  if (attempt > maxAttempts) {",
                  "    pm.expect.fail('轮询' + maxAttempts + '次（约' + (maxAttempts-1)*delayMs/1000 + '秒）仍未找到秒杀订单');",
                  "    return;",
                  "  }",
                  "  pm.sendRequest({",
                  "    url: baseUrl + '/api/order/list?page=1&size=50',",
                  "    method: 'GET',",
                  "    header: {",
                  "      'Authorization': 'Bearer ' + token,",
                  "      'X-User-Id': userId",
                  "    }",
                  "  }, function (err, res) {",
                  "    if (err) {",
                  "      console.log('请求失败 (attempt ' + attempt + '): ' + JSON.stringify(err));",
                  "      setTimeout(() => pollForOrder(attempt + 1), delayMs);",
                  "      return;",
                  "    }",
                  "    const json = res.json();",
                  "    const records = json.data && json.data.records ? json.data.records : [];",
                  "    const found = records.find(o => String(o.seckillActivityId) === String(aid));",
                  "    if (found) {",
                  "      pm.expect(found.status).to.eql('SUCCESS');",
                  "      console.log('秒杀订单确认 (attempt ' + attempt + '): orderId=' + found.id + ', status=' + found.status + ' -- WebSocket推送验证通过');",
                  "    } else if (attempt >= maxAttempts) {",
                  "      pm.expect.fail('秒杀订单未创建，MQ消费延迟超过' + ((maxAttempts-1)*delayMs/1000) + '秒');",
                  "    } else {",
                  "      console.log('秒杀订单尚未就绪 (attempt ' + attempt + ')，' + (delayMs/1000) + '秒后重试...');",
                  "      setTimeout(() => pollForOrder(attempt + 1), delayMs);",
                  "    }",
                  "  });",
                  "}",
                  "",
                  "pollForOrder(1);"
                ],
                "type": "text/javascript"
              }
            }
          ],
