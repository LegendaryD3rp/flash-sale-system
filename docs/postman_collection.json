          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var url=pm.collectionVariables.get('base_url')+'/api/order/list?page=1&size=50';",
                  "var tok=pm.collectionVariables.get('token');",
                  "var uid=pm.collectionVariables.get('userId');",
                  "var aid=Number(pm.collectionVariables.get('activityId'));",
                  "var MAX=15,DELAY=2000;",
                  "(function poll(n){",
                  "if(n>MAX){pm.expect.fail('轮询'+MAX+'次后仍未找到秒杀订单');return;}",
                  "pm.sendRequest({url:url,method:'GET',",
                  "header:{'Authorization':'Bearer '+tok,'X-User-Id':uid}},function(e,r){",
                  "if(e){setTimeout(function(){poll(n+1)},DELAY);return;}",
                  "var recs=r.json().data.records||[];",
                  "var f=recs.find(function(o){return String(o.seckillActivityId)===String(aid)});",
                  "if(f){pm.expect(f.status).to.eql('SUCCESS');",
                  "console.log('秒杀订单确认 ('+n+'/'+MAX+'): id='+f.id+', status='+f.status);}",
                  "else if(n>=MAX){pm.expect.fail('秒杀订单未创建，MQ延迟超过'+((MAX-1)*DELAY/1000)+'秒');}",
                  "else{console.log('等待中 ('+n+'/'+MAX+')...');setTimeout(function(){poll(n+1)},DELAY);}",
                  "});})(1);"
                ],
                "type": "text/javascript"
              }
            }
          ],
