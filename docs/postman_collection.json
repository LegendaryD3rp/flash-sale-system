    {
      "name": "6-秒杀",
      "item": [
        {
          "name": "✅ 6.1 [管理员]创建秒杀活动（动态时间）",
          "event": [{
            "listen": "prereq",
            "script": {
              "exec": [
                "const now = new Date();",
                "const startTime = new Date(now.getTime() - 60000).toISOString().slice(0,19);",
                "const endTime = new Date(now.getTime() + 86400000).toISOString().slice(0,19);",
                "pm.variables.set('dynamicStart', startTime);",
                "pm.variables.set('dynamicEnd', endTime);"
              ],
              "type": "text/javascript"
            }
          },{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "pm.expect(pm.response.code).to.eql(200);",
                "pm.expect(json.code).to.eql(0);",
                "pm.expect(json.data).to.be.a('number');",
                "pm.collectionVariables.set('activityId', String(json.data));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"productId\":{{productId}},\"seckillPrice\":9900,\"totalStock\":200,\"startTime\":\"{{dynamicStart}}\",\"endTime\":\"{{dynamicEnd}}\"}"
            },
            "url": {"raw": "{{base_url}}/api/seckill/activity", "host": ["{{base_url}}"], "path": ["api","seckill","activity"]}
          }
        },
        {
          "name": "✅ 6.2 启用活动并预热到Redis",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.expect(pm.response.code).to.be.oneOf([200, 204]);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-User-Role", "value": "ADMIN"}
            ],
            "body": {"mode": "raw", "raw": "{\"status\":\"ACTIVE\"}"},
            "url": {"raw": "{{base_url}}/api/seckill/activity/{{activityId}}/status", "host": ["{{base_url}}"], "path": ["api","seckill","activity","{{activityId}}","status"]}
          }
        },
        {
          "name": "✅ 6.3 预热（库存写入Redis）",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.expect(pm.response.code).to.be.oneOf([200, 204]);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{}"},
            "url": {"raw": "{{base_url}}/api/seckill/activity/{{activityId}}/warm-up", "host": ["{{base_url}}"], "path": ["api","seckill","activity","{{activityId}}","warm-up"]}
          }
        },
        {
          "name": "✅ 6.4 用户秒杀抢购",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "pm.expect(pm.response.code).to.eql(200);",
                "pm.expect(json.code).to.eql(0);",
                "console.log('秒杀返回: ' + JSON.stringify(json));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-User-Id", "value": "{{userId}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"activityId\":{{activityId}}}"},
            "url": {"raw": "{{base_url}}/api/seckill/flash", "host": ["{{base_url}}"], "path": ["api","seckill","flash"]}
          }
        },
        {
          "name": "✅ 6.5 查询订单列表（验证WebSocket推送结果）",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "pm.expect(pm.response.code).to.eql(200);",
                "pm.expect(json.code).to.eql(0);",
                "const aid = Number(pm.collectionVariables.get('activityId'));",
                "const found = json.data.records.find(o => o.seckillActivityId === aid);",
                "if (found) {",
                "  pm.expect(found.status).to.eql('SUCCESS');",
                "  console.log('WebSocket推送验证 ✅ 秒杀订单已创建, status=SUCCESS');",
                "} else {",
                "  console.log('秒杀订单尚未落库，MQ异步处理中，请稍后重试');",
                "  pm.expect.fail('秒杀订单未找到，MQ可能延迟');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "X-User-Id", "value": "{{userId}}"}
            ],
            "url": {"raw": "{{base_url}}/api/order/list?page=1&size=50", "host": ["{{base_url}}"], "path": ["api","order","list"], "query": [{"key":"page","value":"1"},{"key":"size","value":"50"}]}
          }
        },
        {
          "name": "❌ 6.6 库存不足秒杀（异常—重复秒杀同一活动）",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
