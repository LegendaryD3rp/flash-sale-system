          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"username\":\"{{testUser}}\",\"password\":\"w123456\",\"role\":\"CUSTOMER\"}"},
            "url": {"raw": "{{base_url}}/api/user/register", "host": ["{{base_url}}"], "path": ["api","user","register"]}
