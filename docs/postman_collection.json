    {
      "name": "6-秒杀（含轮询+Redis验证）",
      "item": [
        {
          "name": "✅ 6.1 [管理员]创建秒杀活动（动态时间——5秒前开始）",
          "event": [
            {
              "listen": "prereq",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "const startTime = new Date(now.getTime() - 5000).toISOString().slice(0,19);",
                  "const endTime = new Date(now.getTime() + 86400000).toISOString().slice(0,19);",
                  "pm.variables.set('dynamicStart', startTime);",
                  "pm.variables.set('dynamicEnd', endTime);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.expect(pm.response.code).to.eql(200);",
                  "pm.expect(json.code).to.eql(0);",
                  "pm.expect(json.data).to.be.a('number');",
                  "pm.collectionVariables.set('activityId', String(json.data));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/seckill/activity",
              "path": [
                "api",
                "seckill",
                "activity"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"productId\":{{productId}},\"seckillPrice\":9900,\"totalStock\":200,\"startTime\":\"{{dynamicStart}}\",\"endTime\":\"{{dynamicEnd}}\"}"
            }
          }
        },
        {
          "name": "✅ 6.2 启用活动",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.expect(pm.response.code).to.be.oneOf([200, 204]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Role",
                "value": "ADMIN"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/seckill/activity/{{activityId}}/status",
              "path": [
                "api",
                "seckill",
                "activity",
                "{{activityId}}",
                "status"
              ]
